{
  "name": "pesacheck",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepare": "simple-git-hooks",
    "clean": "rm -rf .next node_modules"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css}": "biome check --write --no-errors-on-unmatched"
  },
  "dependencies": {
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "swiper": "^12.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^22",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "lint-staged": "^17.0.7",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
}
