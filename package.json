{
	"name": "pesacheck",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"prepare": "simple-git-hooks"
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm exec lint-staged"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json,css}": "biome check --write --no-errors-on-unmatched"
	},
	"dependencies": {
		"next": "16.2.9",
		"react": "19.2.4",
		"react-dom": "19.2.4"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"lint-staged": "^17.0.7",
		"simple-git-hooks": "^2.13.1",
		"tailwindcss": "^4",
		"typescript": "^5"
	}
}
