# GraphQL endpoint exposing the swp_* schema over the Publisher Postgres.
NEXT_PUBLIC_API_URL=https://pesacheckstaging-hasura.superdesk.org/v1/graphql

# Tenant to filter every query by (staging PesaCheck tenant).
NEXT_PUBLIC_TENANT_CODE=e6lkum

# Base URL for media bytes; image URLs are built as ${MEDIA_URL}${asset_id}.webp
NEXT_PUBLIC_MEDIA_URL=https://pesacheck-staging-publisher.superdesk.pro/media/
